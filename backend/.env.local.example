# Copy this file to .env.local and fill your own secrets.
# Do not commit .env.local (it is gitignored).
# Spring Boot auto-loads .env.local via `spring.config.import`.

# Neon JDBC URL format required by Spring Boot:
# jdbc:postgresql://<host>/<database>?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxxxx-pooler.c-6.us-east-1.aws.neon.tech/smartcampus?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=replace-with-your-password

JWT_SECRET=change-me
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
